# Med Fellows Environment Variables

# MongoDB Configuration
MONGO_URL=mongodb://localhost:27017
DB_NAME=medfellows

# Application URL (use your production domain)
NEXT_PUBLIC_BASE_URL=https://med-fellows.emergent.host

# CORS Origins (use * for development, specific domains for production)
CORS_ORIGINS=*

# JazzCash Payment Gateway (to be configured)
# JAZZCASH_MERCHANT_ID=your_merchant_id
# JAZZCASH_PASSWORD=your_password
# JAZZCASH_INTEGRITY_SALT=your_salt
# JAZZCASH_MODE=sandbox

# Google Analytics (optional)
# NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX

# Google Search Console (optional)
# GOOGLE_SITE_VERIFICATION=your_verification_token
